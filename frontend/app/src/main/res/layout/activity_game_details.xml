<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <TextView
            android:id="@+id/tvDetailGameName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Game Name"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="12dp" />

        <TextView
            android:id="@+id/tvDetailProvider"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Provider"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailStars"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Stars"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailRisk"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Risk"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailBetCategory"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Bet Category"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailMinBet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Min Bet"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailMaxBet"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Max Bet"
            android:layout_marginBottom="8dp" />

        <TextView
            android:id="@+id/tvDetailJackpot"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Jackpot"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etBetAmount"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Bet Amount"
            android:inputType="numberDecimal"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnPlay"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Play"
            android:layout_marginBottom="16dp" />

        <EditText
            android:id="@+id/etRating"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Rating 1-5"
            android:inputType="number"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/btnRate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Rate Game" />

    </LinearLayout>
</ScrollView>